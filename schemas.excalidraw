    {
      "id": "PxJjhcRdw2FjM44Kvhh9Q",
      "type": "text",
      "x": -549.938375694933,
      "y": 19852.284781968883,
      "width": 1477.11572265625,
      "height": 495,
      "angle": 0,
      "strokeColor": "#1e1e1e",
