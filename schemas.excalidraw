      "index": "bZe",
      "roundness": null,
      "seed": 1849693500,
      "version": 569,
      "versionNonce": 314439879,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773215737425,
      "link": null,
      "locked": false,
      "text": "* TU sur les objets/composants\n\n    * objet data : client, entreprise, recette, produit\n        - constructeur : TU constructeur explicite\n        - properties (ou attributs) + getter/setter/...  => TU si accesseur explicite (setter + validation)\n        - assez souvent pas d'algo\n\n        - cas particulier d'un modèle ORM avec meta code (ou serialisation JSON/XML/...)\n            .NET : attribute\n            Java et TS : annotation\n            Python : decoration\n        => TU dans le composant exploitant le meta code : persistence, serialisation\n\n    * composant : service, repository, controller",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "* TU sur les objets/composants\n\n    * objet data : client, entreprise, recette, produit\n        - constructeur : TU constructeur explicite\n        - properties (ou attributs) + getter/setter/...  => TU si accesseur explicite (setter + validation)\n        - assez souvent pas d'algo\n\n        - cas particulier d'un modèle ORM avec meta code (ou serialisation JSON/XML/...)\n            .NET : attribute\n            Java et TS : annotation\n            Python : decoration\n        => TU dans le composant exploitant le meta code : persistence, serialisation\n\n    * composant : service, repository, controller",
      "autoResize": true,
      "lineHeight": 1.25
    },
