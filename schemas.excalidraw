    {
      "id": "7KkwnIIlOIYIrEShDmo0I",
      "type": "text",
      "x": -657.4787281976011,
      "y": 14906.658575179306,
      "width": 1143.3956298828125,
      "height": 585,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "baz",
      "roundness": null,
      "seed": 72603908,
      "version": 460,
      "versionNonce": 798658377,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773215737425,
      "link": null,
      "locked": false,
      "text": "Cas d'étude .NET\n\n    * fichier existe ou pas : Fixture fichier test specifique au TU\n    * composant Mock avec 2 fonctions : load, isOk\n        1er cas : load error \n            * Setup appel load => throw error\n            * Pas de setup pour l'appel isOK\n            * Verif appel 1 fois du load\n            * Verif 0 appel du isOk\n        2e cas : load false\n        3e cas : load true, isOk error\n        4e cas : load true, isOk true\n        5e cas : load true, isOk false",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cas d'étude .NET\n\n    * fichier existe ou pas : Fixture fichier test specifique au TU\n    * composant Mock avec 2 fonctions : load, isOk\n        1er cas : load error \n            * Setup appel load => throw error\n            * Pas de setup pour l'appel isOK\n            * Verif appel 1 fois du load\n            * Verif 0 appel du isOk\n        2e cas : load false\n        3e cas : load true, isOk error\n        4e cas : load true, isOk true\n        5e cas : load true, isOk false",
      "autoResize": true,
      "lineHeight": 1.25
    },
