    {
      "id": "94aOYJA4mlmlHEMybW-hj",
      "type": "text",
      "x": 359.25639707543047,
      "y": 5246.401629399992,
      "width": 1207.5115966796875,
      "height": 1485,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
