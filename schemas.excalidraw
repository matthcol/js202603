    {
      "id": "xS2ZltrmPXRrwOcYiI7fT",
      "type": "text",
      "x": -265.2793137214105,
      "y": 10818.115147166143,
      "width": 1828.763427734375,
      "height": 630,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
